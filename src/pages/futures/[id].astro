---
import Layout from '../../layouts/Layout.astro';
import DealCard from '../../components/DealCard.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LatestBlogs from '../../components/LatestBlogs.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
	const coupons = await getCollection('coupons');
    // Filter for futures firms
    const futuresCoupons = coupons.filter(c => c.data.category.toLowerCase() === 'futures');
    // Get unique firms (dedup by canonical_slug, but keep original id for URL)
    const seen = new Set();
    const uniqueFirms = futuresCoupons.filter(c => {
        const key = c.data.canonical_slug || c.data.id;
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
    });

	return uniqueFirms.map((c) => {
        const deal = c.data;
        return {
            params: { id: deal.id },
            props: { deal: deal },
        };
    });
}

const { deal } = Astro.props;

// Fetch ALL deals for this firm in this category
const allCoupons = await getCollection('coupons');
const now = Date.now();
const firmDeals = allCoupons
    .filter(c => c.data.firm_name === deal.firm_name && c.data.category.toLowerCase() === 'futures' && new Date(c.data.expiry_date || '2099-12-31').getTime() > now)
    .map(c => c.data);

// Try to fetch rich content from Markdown
// Priority: review_slug (explicit) → canonical_slug → id
const reviewId = deal.review_slug || deal.canonical_slug || deal.id;
let blogPost = null;
try { blogPost = await getEntry('reviews', reviewId); } catch {}
const { Content } = blogPost ? await blogPost.render() : { Content: null };

const pageTitle = `${deal.firm_name} Review & Coupons (Futures) | GoPropReels`;
const metaDesc = deal.description && deal.description.length > 155
    ? deal.description.substring(0, 152) + '...'
    : deal.description || `Explore ${deal.firm_name} prop firm details...`;
---

<Layout title={pageTitle} description={metaDesc}>
    <!-- Schema: Product -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Product",
        "name": `${deal.firm_name} Trading Challenge`,
        "description": deal.description,
        "brand": { "@type": "Brand", "name": deal.firm_name },
        ...(deal.trust_score && parseFloat(deal.trust_score) > 0 && deal.reviews_count && parseInt(deal.reviews_count) > 0 ? {
            "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": parseFloat(deal.trust_score),
                "reviewCount": parseInt(deal.reviews_count),
                "bestRating": 5
            }
        } : {}),
        "offers": (deal.challenges || []).slice(0,3).map(c => ({
            "@type": "Offer",
            "price": c.price,
            "priceCurrency": c.currency || "USD",
            "availability": "https://schema.org/InStock",
            "url": deal.affiliate_link,
            "name": c.name
        }))
    })} />
    <!-- Schema: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://gopropreels.com" },
            { "@type": "ListItem", "position": 2, "name": "Futures Firms", "item": "https://gopropreels.com/futures" },
            { "@type": "ListItem", "position": 3, "name": deal.firm_name, "item": `https://gopropreels.com/futures/${deal.canonical_slug || deal.id}` }
        ]
    })} />
    <!-- Schema: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": `What platforms does ${deal.firm_name} support?`,
                "acceptedAnswer": { "@type": "Answer", "text": (deal.platforms || []).join(', ') || 'See firm website for details.' }
            },
            {
                "@type": "Question",
                "name": `What instruments can I trade at ${deal.firm_name}?`,
                "acceptedAnswer": { "@type": "Answer", "text": (deal.instruments || []).join(', ') || 'Futures contracts.' }
            },
            {
                "@type": "Question",
                "name": `What is the payout policy at ${deal.firm_name}?`,
                "acceptedAnswer": { "@type": "Answer", "text": deal.payout_policy?.details || `${deal.firm_name} offers competitive profit splits for funded futures traders.` }
            }
        ]
    })} />
    <Header />
    
    <main class="relative mx-auto flex max-w-5xl flex-col gap-12 px-4 py-16 text-white">
        {/* Breadcrumb */}
        <nav class="flex items-center gap-2 text-sm text-white/60" aria-label="Breadcrumb">
            <a href="/" class="hover:text-white transition">Home</a>
            <span>/</span>
            <a href="/futures" class="hover:text-white transition">Futures Firms</a>
            <span>/</span>
            <span class="text-brand-accent">{deal.firm_name}</span>
        </nav>

        <header class="flex flex-col md:flex-row items-center gap-8 rounded-3xl border border-white/10 bg-white/5 p-8">
            <div class="h-32 w-32 shrink-0 overflow-hidden rounded-2xl bg-white/10 p-4">
                <img src={deal.firm_logo} alt={deal.firm_name} class="h-full w-full object-contain" />
            </div>
            <div class="text-center md:text-left">
                <div class="inline-flex items-center gap-2 rounded-full bg-futures/10 border border-futures/20 px-3 py-1 text-[10px] font-black uppercase text-futures mb-4">
                    <i class="fa-solid fa-chart-line"></i>
                    Futures Trading Partner
                </div>
                <h1 class="text-4xl font-black mb-2">{deal.broker || deal.firm_name}</h1>
                <p class="text-white/60 text-lg max-w-2xl">{deal.description || `Comprehensive review and active coupons for ${deal.firm_name}.`}</p>
            </div>
        </header>

        <section class="grid gap-12 lg:grid-cols-[1.2fr,0.8fr]">
            <div class="space-y-12">
                {/* Content Section */}
                <article class="prose prose-invert max-w-none">
                    <h2 class="text-3xl font-black mb-8 border-l-4 border-brand-accent pl-6">Firm Intel & Review</h2>
                    {Content ? <Content /> : <div set:html={deal.seo_content} />}
                </article>

                {/* Firm Deals List */}
                <section>
                    <h3 class="text-2xl font-black mb-6">Active {deal.firm_name} Coupons</h3>
                    <div class="grid gap-6 sm:grid-cols-2">
                        {firmDeals.map(d => (
                            <DealCard deal={d} />
                        ))}
                    </div>
                </section>
            </div>

            <aside class="space-y-8">
                {/* Quick Info Box */}
                <div class="rounded-3xl border border-white/10 bg-black/40 p-6">
                    <h3 class="text-lg font-bold mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-circle-info text-brand-accent"></i>
                        Quick Summary
                    </h3>
                    <ul class="space-y-4 text-sm text-white/70">
                        <li class="flex items-center justify-between border-b border-white/5 pb-3">
                            <span class="text-white">Category</span>
                            <span class="font-bold text-futures uppercase">{deal.category}</span>
                        </li>
                        <li class="flex items-center justify-between border-b border-white/5 pb-3">
                            <span class="text-white">Verification Status</span>
                            <span class="text-green-400 font-bold">✓ Verified Firm</span>
                        </li>
                    </ul>
                </div>

                <div class="space-y-4">
					<h3 class="text-lg font-semibold px-2">Latest Insights</h3>
					<LatestBlogs />
				</div>
            </aside>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .text-futures {
        color: #facc15;
    }
    .bg-futures\/10 {
        background-color: rgba(250, 204, 21, 0.1);
    }
    .border-futures\/20 {
        border-color: rgba(250, 204, 21, 0.2);
    }
</style>
