---
import { generateImageAltText } from '../utils/seo';
import DynamicPoster from './DynamicPoster.astro';

interface VideoSource {
	type: 'image' | 'youtube';
	src?: string;
	id?: string;
}

interface Deal {
	id: string;
	canonical_slug?: string;
	firm_name: string;
	title: string;
	description: string;
	category: string;
	discount_highlight: string;
	coupon_code: string;
	theme_color: string;
	video_source: VideoSource;
	features: string[];
	affiliate_link: string;
	key_benefit?: string;
	expiration_date?: string;
	trust_score?: number | string;
}

const { deal, ...rest } = Astro.props as { deal: Deal; [key: string]: any };
const accentColor = deal.theme_color || '#3B82F6';

const initiallyHidden = rest['data-initially-hidden'] === 'true';
const imageAlt = generateImageAltText(deal, 'card');

const firmInitial = deal.firm_name.charAt(0);
const dealSlug = deal.canonical_slug || deal.id;

// Expiry check
const today = new Date();
const isExpired = deal.expiration_date
	? new Date(deal.expiration_date + 'T23:59:59') < today
	: false;

const hasCoupon = deal.coupon_code && deal.coupon_code !== 'No Code' && deal.coupon_code !== 'Auto-applied';
---

<article
	class={`group relative aspect-[9/16] w-full overflow-hidden rounded-[40px] border border-white/10 bg-black/40 backdrop-blur-md transition-all duration-500 hover:border-white/20 hover:scale-[1.02] active:scale-[0.98] cursor-pointer ${initiallyHidden ? 'hidden' : ''} ${isExpired ? 'opacity-60' : ''}`}
	style={`--accent:${accentColor};`}
	data-category={deal.category}
	data-firm-name={deal.firm_name}
	data-detail-url={`/coupons/${dealSlug}`}
	onclick={`window.location.href='/coupons/${dealSlug}';`}
	{...rest}
>
    {/* Dynamic Background Poster */}
    <div class="absolute inset-0 z-0">
        <DynamicPoster
            firmName={deal.firm_name}
            discount={deal.discount_highlight}
            themeColor={accentColor}
            variant="background"
            dealId={deal.id}
        />
    </div>

    {/* Gradient overlays */}
    <div class="absolute inset-0 bg-black/50 backdrop-blur-[2px] z-[1]"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent z-[2]"></div>

    <div class="relative h-full flex flex-col p-4 z-10">
        {/* Top Row: category + status + share */}
        <div class="flex items-start justify-between mb-1">
            <div class="flex items-center gap-2">
                <span class="inline-flex w-fit rounded-full bg-white/5 border border-white/10 px-2.5 py-1 text-[9px] font-black uppercase tracking-widest text-white/50">
                    {deal.category}
                </span>
                {isExpired && (
                    <span class="inline-flex rounded-full bg-red-500/20 border border-red-500/30 px-2.5 py-1 text-[9px] font-black uppercase tracking-widest text-red-400">
                        Expired
                    </span>
                )}
            </div>
            <button
                id={`share-${deal.id}`}
                class="share-btn flex h-8 w-8 items-center justify-center rounded-full bg-white/5 text-white/40 border border-white/10 transition hover:bg-white/20 active:scale-95"
                data-deal-id={deal.id}
                data-deal-url={`https://gopropreels.com/coupons/${dealSlug}`}
                data-deal-title={`${deal.firm_name} - ${deal.discount_highlight}`}
                aria-label={`Share ${deal.firm_name} deal`}
                onclick="event.stopPropagation();"
            >
                <i class="fa-solid fa-share-nodes text-xs"></i>
            </button>
        </div>

        {/* TOP: Logo */}
        <div class="flex flex-col items-center pt-2 pb-1">
            <div class="relative">
                <div class="absolute -inset-3 bg-[var(--accent)] opacity-20 blur-xl rounded-full"></div>
                <div
                    class="relative flex h-14 w-14 items-center justify-center rounded-[18px] bg-gradient-to-br from-white/10 to-transparent border border-white/10 text-2xl font-black text-white shadow-2xl"
                    style={`border-color: ${accentColor}40;`}
                >
                    {(deal as any).firm_logo ? (
                        <img
                            src={(deal as any).firm_logo}
                            alt={deal.firm_name}
                            class="h-9 w-9 object-contain"
                            onerror={`window.handleLogoError && window.handleLogoError(this, "${deal.firm_name}");`}
                        />
                    ) : (
                        firmInitial
                    )}
                </div>
            </div>
        </div>

        {/* MIDDLE: Discount badge — grows to fill space, centered */}
        <div class="flex flex-col items-center justify-center text-center flex-1 gap-2 px-1">
            {/* DISCOUNT BADGE */}
            <div
                class="rounded-2xl px-4 py-3 text-center w-full"
                style={`background: ${accentColor}20; border: 1.5px solid ${accentColor}50;`}
            >
                <p class="text-2xl font-black text-white leading-tight">{deal.discount_highlight}</p>
                {deal.description && (
                    <p class="text-[10px] text-white/60 mt-1 line-clamp-1">{deal.description.split('.')[0]}</p>
                )}
            </div>
        </div>

        {/* BOTTOM INFO: Name + Features */}
        <div class="flex flex-col gap-2 pb-1">
            <h3 class="text-base font-black text-white leading-none uppercase tracking-tighter text-center">
                {deal.firm_name}
            </h3>
            {deal.features && deal.features.length > 0 && (
                <ul class="space-y-1 w-full px-1">
                    {deal.features.slice(0, 2).map((f: string) => (
                        <li class="flex items-center gap-2 text-[11px] text-white/70">
                            <span class="h-1.5 w-1.5 rounded-full shrink-0" style={`background:${accentColor};`}></span>
                            <span class="line-clamp-1 text-left">{f}</span>
                        </li>
                    ))}
                </ul>
            )}
        </div>

        {/* Bottom Actions */}
        <div class="pt-2.5 border-t border-white/10 mt-1.5">
            <div class="flex items-center gap-2">
                {hasCoupon ? (
                    <button
                        class="flex-1 rounded-2xl px-4 py-2.5 text-xs font-black text-white uppercase tracking-widest text-center transition active:scale-95"
                        style={`background: ${accentColor}; box-shadow: 0 0 20px ${accentColor}40;`}
                        data-copy-code={deal.coupon_code}
                        data-affiliate={deal.affiliate_link}
                        data-deal-id={deal.id}
                        onclick={`event.stopPropagation(); (function(btn){ var code=btn.dataset.copyCode; var aff=btn.dataset.affiliate; var event=new CustomEvent('open-code-modal',{detail:{code:code,link:'/go/'+btn.dataset.dealId}}); document.dispatchEvent(event); })(this);`}
                        aria-label={`Get coupon code for ${deal.firm_name}`}
                    >
                        <i class="fa-solid fa-tag mr-1.5"></i>
                        GET CODE
                    </button>
                ) : (
                    <a
                        href={deal.affiliate_link || `/coupons/${dealSlug}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex-1 rounded-2xl bg-white px-4 py-2.5 text-xs font-black text-black uppercase tracking-widest text-center transition hover:bg-brand-accent hover:text-white active:scale-95"
                        onclick="event.stopPropagation();"
                    >
                        GET DEAL
                    </a>
                )}
                <a
                    href={`/coupons/${dealSlug}`}
                    class="h-9 w-9 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white transition hover:bg-white/10 active:scale-95"
                    onclick="event.stopPropagation();"
                    aria-label={`View ${deal.firm_name} deal details`}
                >
                    <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
                </a>
            </div>
        </div>
    </div>

    {/* Hover Accent Glow */}
    <div
        class="absolute inset-x-0 bottom-0 h-1 transition-all duration-700 group-hover:h-full group-hover:bg-gradient-to-t group-hover:from-white/5 group-hover:to-transparent pointer-events-none z-0"
        style={`background-image: linear-gradient(to top, ${accentColor}10, transparent);`}
    ></div>
</article>
